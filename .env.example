# MiniMax
MINIMAX_API_KEY=sk-cp-...
MINIMAX_BASE_URL=https://api.minimax.io/anthropic
MINIMAX_MODEL=MiniMax-M2.7

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# Convex (for webhook callbacks)
CONVEX_URL=https://your-project.convex.site
CONVEX_DEPLOY_KEY=

# Server
API_KEY=your-api-key-for-convex-auth
PORT=3001

# Healthchecks (self-hosted: https://healthchecks.booksyaudit.pl/)
# Worker-liveness heartbeats — ONE check per worker PROCESS. Each is pinged
# every 5 min; create the checks with a ~10 min grace window. Leaving a var
# unset is a safe no-op (the cron just skips the ping in local dev).
#   - scrape worker  (WorkerSettings / arq:queue)   → worker_heartbeat
#   - report worker  (ReportWorkerSettings / arq:reports, drains every audit +
#                     on-demand report) → report_worker_heartbeat
HC_PING_BAGENT_WORKER_HEARTBEAT=https://healthchecks.booksyaudit.pl/ping/<uuid>
HC_PING_BAGENT_REPORT_WORKER_HEARTBEAT=https://healthchecks.booksyaudit.pl/ping/<uuid>
